 import streamlit as st
from google import genai

st.set_page_config(
    page_title="공부시간 타이머 + Gemini",
    page_icon="⏱️",
    layout="centered"
)

# -----------------------------
# Gemini 설정
# -----------------------------
try:
    api_key = st.secrets["GEMINI_API_KEY"]
    client = genai.Client(api_key=api_key)
except Exception as e:
    st.error(f"API 키를 불러올 수 없습니다.\n{e}")
    st.stop()

# -----------------------------
# 세션 상태 초기화
# -----------------------------
if "messages" not in st.session_state:
    st.session_state.messages = []

if "seconds" not in st.session_state:
    st.session_state.seconds = 0

if "running" not in st.session_state:
    st.session_state.running = False

# -----------------------------
# 공부시간 타이머
# -----------------------------
st.title("⏱️ 공부시간 타이머")

hours = st.session_state.seconds // 3600
minutes = (st.session_state.seconds % 3600) // 60
seconds = st.session_state.seconds % 60

st.metric(
    "누적 공부 시간",
    f"{hours:02d}:{minutes:02d}:{seconds:02d}"
)

col1, col2, col3 = st.columns(3)

with col1:
    if st.button("▶ 시작"):
        st.session_state.running = True

with col2:
    if st.button("⏸ 일시정지"):
        st.session_state.running = False

with col3:
    if st.button("🔄 초기화"):
        st.session_state.running = False
        st.session_state.seconds = 0
        st.rerun()

# 타이머 동작
if st.session_state.running:
    import time

    time.sleep(1)
    st.session_state.seconds += 1
    st.rerun()

st.divider()

# -----------------------------
# 채팅 기록 표시
# -----------------------------
st.subheader("📚 공부 도우미")

for msg in st.session_state.messages:
    with st.chat_message(msg["role"]):
        st.markdown(msg["content"])

# -----------------------------
# 사용자 입력
# -----------------------------
prompt = st.chat_input("공부 관련 질문을 입력하세요")

if prompt:
    st.session_state.messages.append(
        {"role": "user", "content": prompt}
    )

